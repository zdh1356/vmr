[
  {
    "start": 0.0,
    "end": 1.04,
    "text": "They didn't eat in Hawaii."
  },
  {
    "start": 1.54,
    "end": 3.04,
    "text": "They didn't really like the fish."
  },
  {
    "start": 3.04,
    "end": 4.26,
    "text": "Shoot a fish, love the fish."
  },
  {
    "start": 4.34,
    "end": 4.88,
    "text": "Yeah, it was good."
  },
  {
    "start": 5.02,
    "end": 5.48,
    "text": "You'll cry."
  },
  {
    "start": 5.56,
    "end": 6.22,
    "text": "We don't cry."
  },
  {
    "start": 6.34,
    "end": 7.2,
    "text": "Oh, yeah."
  },
  {
    "start": 8.0,
    "end": 9.1,
    "text": "You know, one of these days,"
  },
  {
    "start": 9.26,
    "end": 12.08,
    "text": "if you don't show one of those tourists such a blue pack,"
  },
  {
    "start": 12.44,
    "end": 13.8,
    "text": "she won't want to stay on the island, bro."
  },
  {
    "start": 14.06,
    "end": 16.26,
    "text": "Now, why do you say such mean things to me like that?"
  },
  {
    "start": 16.3,
    "end": 17.62,
    "text": "And why is your food on my pillow?"
  },
  {
    "start": 20.08,
    "end": 21.0,
    "text": "I know you're asking,"
  },
  {
    "start": 21.2,
    "end": 21.88,
    "text": "I need to get out."
  },
  {
    "start": 22.0,
    "end": 22.6,
    "text": "Get out."
  },
  {
    "start": 23.24,
    "end": 24.1,
    "text": "You could have been."
  },
  {
    "start": 25.16,
    "end": 27.84,
    "text": "Then you won't be able to go on your big boat trip to Alaska."
  },
  {
    "start": 27.84,
    "end": 31.42,
    "text": "You can stop here and wait down next to the same old,"
  },
  {
    "start": 31.52,
    "end": 32.24,
    "text": "ugly frog."
  }
]