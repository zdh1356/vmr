[
  {
    "start": 0.0,
    "end": 2.0,
    "text": "फॉर फिगर सेलरी कॉर्मेंट हेजुकेज़े"
  },
  {
    "start": 2.0,
    "end": 5.0,
    "text": "उसका अपना खुद का फिगर भी इच्छा है"
  },
  {
    "start": 5.0,
    "end": 8.0,
    "text": "मम्मा बोलो ये साइट से विपाशा टाइप लगती"
  },
  {
    "start": 8.0,
    "end": 9.0,
    "text": "विपाशा की मैंने पिक्चर देखे नहीं तो"
  },
  {
    "start": 9.0,
    "end": 11.0,
    "text": "आज सारी वीसीटी लेके आउंगा उसकी देखूँगा"
  },
  {
    "start": 11.0,
    "end": 13.0,
    "text": "विपाशा"
  },
  {
    "start": 13.0,
    "end": 15.0,
    "text": "लेकिन बिना वासित नहीं हुआ थे"
  },
  {
    "start": 15.0,
    "end": 16.8,
    "text": "कैसे शादी कर सकते हैं?"
  },
  {
    "start": 16.8,
    "end": 18.0,
    "text": "वासित भाग में हो जाएगा"
  },
  {
    "start": 18.0,
    "end": 20.0,
    "text": "अगर नहीं हुआ तो?"
  },
  {
    "start": 20.0,
    "end": 25.0,
    "text": "अगर रिश्ता को वासित फंतल बिलकुल घटने नहीं और भी खासे चलेगा लेकर ओग सब्सक्राइब कर सकता है"
  },
  {
    "start": 25.0,
    "end": 26.5,
    "text": "इसका में करावी चेन कर दो"
  },
  {
    "start": 26.66,
    "end": 29.66,
    "text": "यार यार खटे से हो जाएगा"
  },
  {
    "start": 30.4,
    "end": 32.44,
    "text": "चांस दे रहा हूँ खटे से भी जाता है"
  },
  {
    "start": 33.44,
    "end": 35.38,
    "text": "यार एवरीथिंग विदि ऑर राइट"
  },
  {
