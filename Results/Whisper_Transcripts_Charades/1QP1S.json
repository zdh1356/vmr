[
  {
    "start": 0.0,
    "end": 7.0,
    "text": "சிறிது முன்னிடம் சாப்பிடினால் வேண்டும்."
  },
  {
    "start": 15.0,
    "end": 18.0,
    "text": "இருவரும் சாப்பிடினீர்கள்."
  },
  {
    "start": 18.0,
    "end": 23.0,
    "text": "சாப்பிடினால், குறிப்பையில் பார்க்கலாம்."
  },
  {
    "start": 23.0,
    "end": 24.0,
    "text": "ஹா!"
  },
  {
    "start": 26.0,
    "end": 27.0,
    "text": "ஏன் அப்பா சிறியும்?"
  },
  {
    "start": 28.0,
    "end": 29.0,
    "text": "அப்பாற்ற பார்த்து சிறியும்"
  }
]