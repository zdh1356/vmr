[
  {
    "start": 0.0,
    "end": 12.5,
    "text": "المنظومة لهذه الهيئة العالمية"
  },
  {
    "start": 12.5,
    "end": 16.42,
    "text": "هنا أكبر دليل يا الله"
  },
  {
    "start": 16.42,
    "end": 23.0,
    "text": "يا سلام على فرانسيسكو ألفز"
  },
  {
    "start": 23.0,
    "end": 27.16,
    "text": "هنا المتابعة هنا العكسية"
  },
  {
    "start": 27.16,
    "end": 31.44,
    "text": "ثلاثة مقابل واحد البرازيل الآن يا الله"
  },
  {
    "start": 31.44,
    "end": 38.08,
    "text": "يا يا يا على هذه الفرصة"
  },
  {
    "start": 38.08,
    "end": 42.06,
    "text": "يا سلام على البرازيل"
  },
  {
    "start": 42.06,
    "end": 45.44,
    "text": "هدف مميز ومميز جدا"
  },
  {
    "start": 45.44,
    "end": 49.62,
    "text": "كما ذكرت لاحظة الإعادة تابع تابع"
  },
  {
    "start": 49.62,
    "end": 54.0,
    "text": "تابع ثلاثة مقابل واحد تابع المهارات يا سلام"
  },
  {
    "start": 54.0,
    "end": 55.96,
    "text": "الأرجنتي في الساعة الخامسة"
  },
  {
    "start": 55.96,
    "end": 59.06,
    "text": "ومن ثم السابع ونصف واتيمانا مع البرازيل"
  },
  {
    "start": 59.06,
    "end": 63.54,
    "text": "هنا المحاولة ولكن إذن إكتوارا"
  },
  {
    "start": 63.54,
    "end": 67.88,
    "text": "إكتوارا حارس المرمى"
  },
  {
    "start": 67.88,
    "end": 75.0,
    "text": "هنا المتابعة يا الله"
  },
  {
    "start": 75.0,
    "end": 81.32,
    "text": "يا سلام يا سلام سلم"
  },
  {
    "start": 81.32,
    "end": 84.64,
    "text": "يا سلام على أليكزاندر فارية"
  },
  {
    "start": 85.96,
    "end": 91.96,
    "text": "لتمرير إلى دار اللوبز الثلاثية الآن في اليابان في هذه اللحظات"
  },
  {
    "start": 91.96,
    "end": 96.1,
    "text": "بثلاثة مقابل لا شيء لاحظ"
  },
  {
    "start": 96.1,
    "end": 102.36,
    "text": "اثنين مقابل واحد الرابع الرابع الرابع الرابع الرابع يا الله"
  },
  {
    "start": 102.36,
    "end": 107.96,
    "text": "الرابع من دار اللوبز اثنين هدفين لهذا اللحظة"
  },
  {
    "start": 107.96,
    "end": 113.96,
    "text": "طولات عديدة رابيل طولات عديدة من رابيل نوفياز"
  },
  {
    "start": 115.96,
    "end": 122.96,
    "text": "شارك في العديد من البطولات هنا في الكويت"
  },
  {
    "start": 122.96,
    "end": 126.96,
    "text": "كرة اللعب محاولة والهدف الخامس"
  },
  {
    "start": 126.96,
    "end": 130.96,
    "text": "الهدف الخامس يأتي للبرازيل"
  },
  {
    "start": 130.96,
    "end": 135.96,
    "text": "الهدف الخامس للبرازيل من عن طريق اللاعب كارمان"
