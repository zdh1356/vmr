[
  {
    "start": 0.0,
    "end": 6.0,
    "text": "Акмад Абергенов из Узбекистана"
  },
  {
    "start": 30.0,
    "end": 32.0,
    "text": "Держи, держи!"
  },
  {
    "start": 40.0,
    "end": 42.0,
    "text": "Еще раз такой же победа!"
  },
  {
