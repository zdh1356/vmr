  {
    "start": 92.0,
    "end": 93.04,
    "text": "E ancora!"
  },
  {
    "start": 93.96,
    "end": 94.3,
    "text": "Gol!"
  },
  {
    "start": 95.4,
    "end": 96.84,
    "text": "Devi non stare tanto ancora in gioco."
  },
  {
    "start": 100.26,
    "end": 102.94,
    "text": "Rivio sbagliato, poi c'è Farina che scarica al destro."
  },
  {
    "start": 104.38,
    "end": 105.28,
    "text": "Attenzione, l'errore!"
  },
  {
    "start": 105.56,
    "end": 108.64,
    "text": "L'errore di Ruggeri che favorisce."
  },
  {
    "start": 109.7,
    "end": 112.62,
    "text": "Adesso c'è un calcio d'angolo, va il solito Battista sul pallone."
  },
  {
    "start": 113.68,
    "end": 114.52,
    "text": "Che mette al centro!"
  },
  {
    "start": 116.02,
    "end": 117.74,
    "text": "E la palla toccata."
  },
  {
    "start": 118.56,
    "end": 119.66,
    "text": "Buona, buona, va bene!"
  },
  {
    "start": 120.54,
    "end": 121.44,
    "text": "Palla buttata via."
  },
  {
    "start": 122.0,
    "end": 125.04,
    "text": "Battista."
  },
  {
    "start": 126.24,
    "end": 128.1,
    "text": "Per Joderil!"
  },
  {
    "start": 128.54,
    "end": 130.24,
    "text": "La sforbiciata, il pallone..."
  },
  {
    "start": 130.24,
    "end": 132.12,
    "text": "Non vedo niente."
  },
  {
    "start": 133.34,
    "end": 138.04,
    "text": "Calcio d'angolo battuto, il pallone finisce sul corpo di Ceyenne."
  },
  {
    "start": 138.22,
    "end": 139.78,
    "text": "Che poi spazza via."
  },
  {
    "start": 140.88,
    "end": 142.98,
    "text": "C'è Jaber in fase difensiva."
  },
  {
    "start": 143.16,
    "end": 144.32,
    "text": "Che perde il pallone però!"
  },
  {
    "start": 144.7,
    "end": 149.0,
    "text": "Marinelli il destro, il portiere esce ma il pallone ancora..."
  },
  {
    "start": 150.26,
    "end": 150.7,
    "text": "Anzi no."
  },
  {
    "start": 151.2,
    "end": 151.8,
    "text": "Jaber riesce..."
  },
  {
    "start": 151.8,
    "end": 153.8,
    "text": "Riesce a districarsi."
  },
  {
    "start": 154.84,
    "end": 156.84,
    "text": "Poi Joderi con il sinistro."
  },
  {
    "start": 159.38,
    "end": 162.74,
    "text": "Ancora Zuccaro per la squadra degli All Star 86 che si porta in avanti."
  },
  {
    "start": 163.48,
    "end": 164.62,
    "text": "Prova a mettere al centro."
  },
  {
    "start": 176.52,
    "end": 177.66,
    "text": "Chioditti prova a lanciare..."
  }
]