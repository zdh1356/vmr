[
  {
    "start": 0.0,
    "end": 4.0,
    "text": "бһҹбһ¶бһ“бһ–бһ¶бһ“бһ–бһ¶бһӣбһўбһ¶бһҡбһҹбһ¶бһҹбҹ’бһҹбһ¶бһҹбһ“бһ¶бһҹбҹ’бһўбһ¶бһҡбҹғбһҷбһҹбһ“бҹ’бһҹбһ¶бһҹбҹ”"
  },
  {
    "start": 4.0,
    "end": 9.0,
    "text": "бһҹбһ¶бһ“бһ–бһ¶бһӣбһўбһ¶бһҡбҹғбһҹбҹ’бһҹбһ¶бһҹбҹӢбһҖбҹ’бһҳбҹ’бһҠбһҫбһ„бһӣбһ№бһ„бһ“бҹ’бһ‘бҹ…, бһҹбһјбһҳбҹ’бһҳбҹ’бһ‘бҹ…, бһ“бһ№бһ„бһ»бһ“бһ“бҹ’бһҷбһ¶бһ“бһҠбҹӮбһӣбһӣбһ¶бһҡбҹ„бҹҮбһ”бһ¶бһҡбҹ„бҹҮ"
  },
  {
    "start": 9.0,
    "end": 17.62,
    "text": "бһҹбһ»бһҹбҹ’бһӣбһ¶бһ…бһӮбҹӢбһ–бһёбһ”бһ¶бһ“бһҡбҹҖбһ”бһҹбҹ’бһ“бһ¶бһҖбҹӢбһ–бҹ’бһӣбһ¶бһ„бҹӢбһҖбҹ’бһҗбҹ’бһ“бҹӢбһҸбҹӮбһҡбһҹбҹ’бһңбһҫбһҷбһҖбһҳбҹ’бһҸбҹӮбһ”бһ¶бһ“бҹӢбҹ”"
  },
  {
    "start": 17.62,
    "end": 29.98,
    "text": "бһҹбһјбһңбһқбһ“бһӣбҹӮбһӮбһҖбһ¶бһҡбһ”бһҹбҹӢбһҸбһ¶бһ“бһҠбҹӮбһҳбһ¶бһ“бһҠбҹ’бһ…бһ…бҹ’бһ…бһ¶бҹҶбһ„бһ–бҹ’бһҸбҹӮбһ“бҹҮбһҹбҹ’бһҡбһ”бһҹбҹӢбһӣбҹ’бһҳбһ·бһ“бҹ”"
  },
  {
    "start": 29.98,
    "end": 37.98,
    "text": "бһ“бһ№бһ„бҹӢбһ”бһ¶бһ“бһ„бҹӢбһ…бһјбһӣбһ…бҹҶбһ–бһ»бһҸбҹӮбһӣбһ¶бһҡбһ¶бһҹбҹӢбһ”бҹҶбһ–бҹ’бһҡбҹҖбһҸбҹӮбһҡбҹҖбһҸбҹӮбһӣбһ¶бһ“бҹӢбҹ”"
  }
]