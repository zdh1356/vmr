[
  {
    "start": 0.0,
    "end": 1.96,
    "text": "3, 2, 1"
  },
  {
    "start": 30.0,
    "end": 52.44,
    "text": "Why do I skate?"
  },
  {
    "start": 53.8,
    "end": 54.36,
    "text": "Gosh."
  },
  {
    "start": 54.82,
    "end": 56.68,
    "text": "I love skating."
  },
  {
    "start": 56.88,
    "end": 58.22,
    "text": "It's truly all I've ever known."
  },
  {
    "start": 58.22,
    "end": 59.94,
    "text": "And it's what I had."
  },
  {
    "start": 60.0,
    "end": 60.68,
    "text": "Identify as."
  },
  {
    "start": 60.76,
    "end": 62.94,
    "text": "I mean, I am a rollerblader."
  },
  {
    "start": 63.12,
    "end": 64.7,
    "text": "You are your skating."
  },
  {
    "start": 65.08,
    "end": 68.94,
    "text": "You get instant gratification after landing your tricks."
  },
  {
    "start": 69.28,
    "end": 72.92,
    "text": "And landing your tricks is really kind of a personal thing."
  },
  {
    "start": 73.0,
    "end": 74.72,
    "text": "I mean, I started skating when I was 15."
  },
  {
    "start": 75.54,
    "end": 77.18,
    "text": "And things sort of progressed from there."
  },
  {
    "start": 77.4,
    "end": 82.88,
    "text": "The coolest, most fun part about skating is if you have a goal in mind, it is the journey."
  },
  {
    "start": 83.04,
    "end": 84.56,
    "text": "I mean, it's about getting there."
  },
  {
    "start": 84.64,
    "end": 85.52,
    "text": "That's the best part."
  },
  {
    "start": 85.62,
    "end": 88.5,
    "text": "Because it opens up the world to whatever you want to do."
  }
]