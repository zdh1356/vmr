[
  {
    "start": 0.0,
    "end": 2.8,
    "text": "бһ”бһ¶бһ“бһӣбһҫбһ„бҹ’бһ„бһ¶бһҷбҹ”"
  },
  {
    "start": 2.8,
    "end": 6.22,
    "text": "бһҳбҹ’бһҡбһ”бһҹбҹӢбһ‘бҹ…бһҖбҹ’бһҡбһҠбһ¶бҹҶбһ„бһ–бһёбһҡбһ”бһҹбҹӢбһҸбһ¶бһҳбһҮбһ¶бһ–бһёбһӣбҹ’бһҡбҹ„бҹҮ"
  },
  {
    "start": 36.22,
    "end": 66.22,
    "text": "бһҮбһ¶бһ“бһҹбһ¶бһҠбһјбһҷбһЎбһјбһӣбһ”бһ¶бһҡбҹҖбһҹбһҹбҹ’бһҹбһ¶бһ…бҹӢбһҖбһ¶бһҡбһҹбҹӢбһҖбһ¶бһҡбһҹбҹӢбһҹбҹ’бһҹбһ¶бһ…бҹҶбһ–бһёбһ”бһ¶бһ“бһЎбҹ’бһҹбһ¶бһ…бҹҶбһҳбһ¶бһ“бһ¶бһ…бҹҶбһңбһ·бһҸбҹ’бһҹбһ¶бһ…бҹҶбһ–бһёбһ”бһ¶бһ“бһ…бҹ’бһ…бһ»бҹҶбһ–бһёбһңбһ¶бһҸбһ·бһҸбҹ’бһҡбһ¶бһӣбһ·бһҸбҹ’бһҡбһҫбһңбҹ’бһҡбҹҖбһҹбһҹбҹ’бһҡбһ¶бҹҶбҹ’пҝҪ"
  },
  {
    "start": 66.22,
    "end": 96.22,
    "text": "бһ…бҹ’бһҡбһӣбһ¶бһӣбҹӢбһҹбһ¶бһҹбһ¶бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһ”бһҹбҹӢбһ”бһүбһ»бҹҮбһҹбҹ’бһ бһ¶бһҹбһ¶бһҡбһ¶бҹҗбһҹбҹӢбһҖбһ¶бһҡбһ“бҹғбһ…бҹ’бһ…бһ»бҹҮбһ“бһ»бһҒбһ–бһёбһҠбһёбһӣбҹ’бһ бһ¶бһҡбһ“бҹғбһӣбһҹбҹ’бһ бһ¶бһҡбһҖбҹ’бһҡбһ¶бһ”бһҹбҹӢбһҹбҹ’бһ бһ¶бһҡбһ”бһҹбҹӢбһҹбҹ’бһ бһ¶бһҡбһҮбһ¶бһҹбҹ’бһўбһ¶ бһҠбҹӮбһӣбһ”бҹ’бһҡбһҙпҝҪ"
  },
  {
    "start": 96.22,
    "end": 126.22,
    "text": "бһ…бҹ’бһҡбһјбһңбһҖбһ¶бһҖбҹӢбһҸбҹӮбһҡбһҪбһҳбҹ” бһ…бһ¶бһҸбҹӢбһҖбһ¶бһҡбһ”бһ¶бһ“бҹӢбһ–бһ¶бһ„бһ–бһ¶бһ–бһҡбҹҗбһ“бҹ’бһ‘бһ¶бҹҶбһ„бһ”бһ¶бһ“бһўбһ¶бҹҶбһ„бһ¶бһ–бһ¶бһҡбһҹбһҹбҹӢбһҹбһ¶бһҳбҹ’бһҡбһјбһңбһҫбһ„бһ“бҹ…бһ–бһёбһ…бҹ’бһ…бһ¶бһҸбҹӢбһҖбһ¶бһҡбһ¶бһ”бҹӢбһҸбҹ’бһҸбһ¶бһҹбһ¶бһ–бһӣбһ•бҹ’бһҸбһ¶бһ“бҹӢбһҹбһ¶бһҡбһ”бһҹбҹӢбһҹпҝҪ"
  },
  {
    "start": 126.22,
    "end": 129.22,
    "text": "бһ”бһ„бҹ’бһ“бһ»бһ„бһ—бҹҒбһ„бһҳбһ¶бһ“бһҡбҹҖбһ”бһ„бһҖбҹ’бһҡбһ¶бһҹбҹҒбһҹбһҳбһ–бҹҒбһӣбҹӢбҹ”"
  },
  {
    "start": 129.22,
    "end": 132.22,
    "text": "бһҹбһјбһңбһ“бһ“бҹғбһ…бһ”бҹӢбһ–бҹҒбһӣбһҖбҹ’бһҡбһёбһңбһ·бһҸбҹ’бһҡбһ¶бһ“бҹӢбһҳбҹ’бһҡбһ¶бһҹбҹӢбһ–бҹҒбһӣбҹӢбҹ”"
  },
  {
    "start": 132.22,
    "end": 134.22,
    "text": "бһҡбһёбһңбһ·бһҸбҹӢбһҳбһ¶бһ“бһҡбһ¶бһ”бҹӢбһҖбҹ’бһҡбһ¶бһҹбҹҒбһӣбҹ”"
  }
]