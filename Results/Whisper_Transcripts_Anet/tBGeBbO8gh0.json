[
  {
    "start": 0.0,
    "end": 5.0,
    "text": "Plastic minimum."
  },
  {
    "start": 5.0,
    "end": 10.0,
    "text": "What the hell is it?"
  },
  {
    "start": 10.0,
    "end": 13.0,
    "text": "We'll find out soon."
  },
  {
    "start": 13.0,
    "end": 16.0,
    "text": "You said pull it out, I'm looking to pull it out."
  },
  {
    "start": 16.0,
    "end": 24.0,
    "text": "Looks like it might be a good one."
  },
  {
    "start": 24.0,
    "end": 26.0,
    "text": "We'll find out."
  },
  {
    "start": 26.0,
    "end": 29.0,
    "text": "Yeah, it's a good male."
  },
  {
    "start": 29.0,
    "end": 34.0,
    "text": "I can see it."
  },
  {
    "start": 34.0,
    "end": 36.0,
    "text": "You want a male one?"
  },
  {
    "start": 36.0,
    "end": 38.0,
    "text": "Paul? You want a male?"
  },
  {
    "start": 38.0,
    "end": 41.0,
    "text": "No."
  },
  {
    "start": 41.0,
    "end": 46.0,
    "text": "No, I don't want to leave right now."
  },
  {
    "start": 46.0,
    "end": 49.0,
    "text": "You don't have to leave, stay a bit."
  },
  {
    "start": 49.0,
    "end": 55.0,
    "text": "It's a good size, it'll get its head up."
  },
  {
    "start": 55.0,
    "end": 57.0,
    "text": "Come on."
  },
  {
    "start": 57.0,
    "end": 60.0,
    "text": "Holy shit."
  },
  {
    "start": 60.0,
    "end": 62.0,
    "text": "No, no, wait, wait, wait."
  },
  {
    "start": 62.0,
    "end": 65.0,
    "text": "You need to hook it right so it doesn't fit in the hole."
  },
  {
    "start": 65.0,
    "end": 69.0,
    "text": "It's too big for the..."
  },
  {
    "start": 69.0,
    "end": 71.0,
    "text": "It's too..."
  },
  {
    "start": 71.0,
    "end": 76.0,
    "text": "Get it in the upper jaw."
  },
  {
    "start": 76.0,
    "end": 83.0,
    "text": "Yes, big old pretty."
  },
  {
    "start": 83.0,
    "end": 84.0,
    "text": "Hey."
  },
  {
    "start": 84.0,
    "end": 85.0,
    "text": "Hey."
  },
  {
    "start": 85.0,
    "end": 90.0,
    "text": "Oh, yeah."
  },
  {
    "start": 90.0,
    "end": 91.0,
    "text": "Ready?"
  },
  {
    "start": 91.0,
    "end": 93.0,
    "text": "I'm breaking his mouth."
  },
  {
    "start": 93.0,
    "end": 95.0,
    "text": "Okay, bring me another glove."
  },
  {
    "start": 95.0,
    "end": 99.0,
    "text": "Big one."
  },
  {
    "start": 99.0,
    "end": 101.0,
    "text": "You want to see it?"
  },
  {
    "start": 101.0,
    "end": 104.0,
    "text": "Put a little oil on him."
  },
  {
    "start": 104.0,
    "end": 109.0,
    "text": "I broke his jaw, look."
  },
  {
    "start": 109.0,
    "end": 114.0,
    "text": "Let me take this one out."
  },
  {
    "start": 114.0,
    "end": 116.0,
    "text": "What can we do?"
  },
  {
    "start": 116.0,
    "end": 118.0,
    "text": "That's a big old fish there."
  },
  {
    "start": 118.0,
    "end": 120.0,
    "text": "I guess you could eat him right there."
  },
  {
    "start": 120.0,
    "end": 123.0,
    "text": "Yeah, well that fish can't live now because he's got a broken jaw."
  },
  {
    "start": 123.0,
    "end": 125.0,
    "text": "No, you got to get him out of there."
  },
  {
    "start": 125.0,
    "end": 126.0,
    "text": "Give him another."
  },
  {
    "start": 126.0,
    "end": 127.0,
    "text": "Get a gaff behind his gill plate."
  },
  {
    "start": 127.0,
    "end": 128.0,
    "text": "Yeah, like that."
  },
  {
    "start": 128.0,
    "end": 130.0,
    "text": "Behind the gill plates."
  },
  {
    "start": 130.0,
    "end": 131.0,
    "text": "You got another gaff?"
  },
  {
    "start": 131.0,
    "end": 132.0,
    "text": "Yeah, here, hold on."
  },
  {
    "start": 132.0,
    "end": 135.0,
    "text": "I got another one."
  },
  {
    "start": 135.0,
    "end": 136.0,
    "text": "That poor bugger."
  },
  {
    "start": 136.0,
    "end": 138.0,
    "text": "Hold on until we get another gaff in."
  },
  {
    "start": 138.0,
    "end": 140.0,
    "text": "He's going to break his face."
  },
  {
    "start": 140.0,
    "end": 141.0,
    "text": "Let's hope."
  },
  {
    "start": 141.0,
    "end": 142.0,
    "text": "Yes, sir."
  },
  {
    "start": 142.0,
    "end": 144.0,
    "text": "Is his jaw broken?"
  },
  {
    "start": 144.0,
    "end": 146.0,
    "text": "Yeah, probably like that."
  },
  {
    "start": 146.0,
    "end": 148.0,
    "text": "Get down behind his gill plates, buddy."
  },
  {
    "start": 148.0,
    "end": 149.0,
    "text": "Way down there."
  },
  {
    "start": 149.0,
    "end": 150.0,
    "text": "Yeah, on the head side."
  },
  {
    "start": 150.0,
    "end": 151.0,
    "text": "That's it."
  },
  {
    "start": 151.0,
    "end": 152.0,
    "text": "Gee."
  },
  {
    "start": 152.0,
    "end": 153.0,
    "text": "What a piece of ."
  },
  {
    "start": 153.0,
    "end": 154.0,
    "text": "I wonder."
  },
  {
    "start": 154.0,
    "end": 155.0,
    "text": "That poor bastard."
  }
]