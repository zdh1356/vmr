[
  {
    "start": 0.0,
    "end": 6.06,
    "text": "今日も走り続ける"
  },
  {
    "start": 6.06,
    "end": 9.72,
    "text": "誰だってランナーだ"
  },
  {
    "start": 9.72,
    "end": 12.64,
    "text": "時計は止められない"
  },
  {
    "start": 12.64,
    "end": 16.26,
    "text": "時間は一方向にしか流れない"
  },
  {
    "start": 16.26,
    "end": 19.58,
    "text": "後戻りできないマラソンコースだ"
  },
  {
    "start": 22.24,
    "end": 24.42,
    "text": "ライバルと競い合いながら"
  },
  {
    "start": 24.42,
    "end": 27.12,
    "text": "時の流れという一本道を"
  },
  {
    "start": 27.12,
    "end": 29.5,
    "text": "僕らは走り続ける"
  },
  {
    "start": 29.5,
    "end": 34.58,
    "text": "より早く一歩でも前に"
  },
  {
    "start": 35.3,
    "end": 37.76,
    "text": "その先に未来があると信じて"
  },
  {
    "start": 37.76,
    "end": 41.58,
    "text": "必ずゴールはあると信じて"
  },
  {
    "start": 42.14,
    "end": 48.7,
    "text": "人生はマラソンだ"
  },
  {
    "start": 53.58,
    "end": 55.68,
    "text": "でも本当にそうか"
  },
  {
    "start": 55.68,
    "end": 58.84,
    "text": "人生ってそういうものか"
  },
  {
    "start": 58.84,
    "end": 59.28,
    "text": "はい"
  },
  {
    "start": 59.28,
    "end": 59.48,
    "text": "はい"
  },
  {
    "start": 59.48,
    "end": 59.5,
    "text": "はい"
  },
  {
    "start": 59.5,
    "end": 60.02,
    "text": "違う"
  },
  {
    "start": 60.02,
    "end": 62.16,
    "text": "人生はマラソンじゃない"
  },
  {
    "start": 62.16,
    "end": 64.88,
    "text": "誰が決めたコースなんだよ"
  },
  {
    "start": 64.88,
    "end": 67.62,
    "text": "誰が決めたゴールなんだよ"
  },
  {
    "start": 67.62,
    "end": 69.06,
    "text": "どこを走ったっていい"
  },
  {
    "start": 69.06,
    "end": 71.08,
    "text": "どこへ向かったっていい"
  },
  {
    "start": 71.08,
    "end": 73.46,
    "text": "自分だけの道があるんだ"
  },
  {
    "start": 73.46,
    "end": 75.3,
    "text": "自分だけの道"
  },
  {
    "start": 75.3,
    "end": 77.06,
    "text": "そんなもんあるのか"
  },
  {
    "start": 77.06,
    "end": 78.56,
    "text": "わからない"
  },
  {
    "start": 78.56,
    "end": 81.92,
    "text": "僕らがまだ出会っていない世界は"
  },
  {
    "start": 81.92,
    "end": 83.84,
    "text": "とてつもなく広い"
  },
  {
    "start": 83.84,
    "end": 84.44,
    "text": "そうだ"
  },
  {
    "start": 84.44,
    "end": 85.82,
    "text": "踏み出すんだ"
  },
  {
    "start": 85.82,
    "end": 87.34,
    "text": "悩んで"
  },
  {
    "start": 87.34,
    "end": 88.56,
    "text": "悩んで"
  },
  {
    "start": 88.56,
    "end": 89.48,
    "text": "さあ"
  },
  {
    "start": 89.48,
    "end": 90.72,
    "text": "最後まで走り抜くんだ"
  },
  {
    "start": 90.72,
    "end": 92.88,
    "text": "失敗してもいい"
  },
  {
    "start": 92.88,
    "end": 94.74,
    "text": "寄り道してもいい"
  },
  {
    "start": 94.74,
    "end": 96.96,
    "text": "誰かと比べなくていい"
  },
  {
    "start": 96.96,
    "end": 99.04,
    "text": "道は一つじゃない"
  },
  {
    "start": 99.04,
    "end": 101.08,
    "text": "ゴールは一つじゃない"
  },
  {
    "start": 101.08,
    "end": 104.38,
    "text": "それは人間の数だけあるんだ"
  },
  {
    "start": 107.56,
    "end": 110.12,
    "text": "全ての人生が素晴らしい"
  },
  {
    "start": 110.12,
    "end": 114.06,
    "text": "誰が人生をマラソンって言ったのか"
  },
  {
    "start": 114.06,
    "end": 117.54,
    "text": "リクルートポイント始まる"
  },
  {
    "start": 117.54,
    "end": 119.06,
    "text": "まだここにない出会い"
  },
  {
    "start": 119.06,
    "end": 119.46,
