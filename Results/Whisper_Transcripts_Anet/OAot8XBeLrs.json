[
  {
    "start": 0.0,
    "end": 3.18,
    "text": "De repente, se o Joãozinho der o drible, a cobertura pode chegar."
  },
  {
    "start": 4.16,
    "end": 6.72,
    "text": "Virou o gol, vem Floripa, vira e põe o giro na trave!"
  },
  {
    "start": 7.04,
    "end": 7.74,
    "text": "Olha a volta!"
  },
  {
    "start": 8.82,
    "end": 15.46,
    "text": "Gol de Florianópolis!"
  },
  {
    "start": 16.08,
    "end": 18.0,
    "text": "Antônio abre o placar!"
  },
  {
    "start": 18.96,
    "end": 22.42,
    "text": "Finalzinho de primeiro tempo, Florianópolis depois do pedido de tempo"
  },
  {
    "start": 22.42,
    "end": 25.82,
    "text": "consegue chegar ao seu gol."
  },
  {
    "start": 25.94,
    "end": 27.8,
    "text": "Primeiro gol do jogo, gol de Antônio."
  },
  {
    "start": 27.8,
    "end": 30.8,
    "text": "Uma jogada rápida na saída em velocidade."
  },
  {
    "start": 31.38,
    "end": 35.6,
    "text": "Comemora o público presente em Florianópolis."
  },
  {
    "start": 36.52,
    "end": 39.72,
    "text": "Mais uma vez, o passe do Renatinho apareceu na referência."
  },
  {
    "start": 39.86,
    "end": 41.2,
    "text": "O Vini fez o giro, tirou o David."
  },
  {
    "start": 41.48,
    "end": 43.32,
    "text": "A bola bateu na trave e aí não tinha ninguém."
  },
  {
    "start": 43.78,
    "end": 47.7,
    "text": "A marcação do Antônio, um gol vazio fica muito mais fácil."
  },
  {
    "start": 48.12,
    "end": 49.28,
    "text": "Floripa 1, Corinthians 0."
  },
  {
    "start": 49.56,
    "end": 50.78,
    "text": "Erro de marcação, né?"
  },
  {
    "start": 52.5,
    "end": 55.82,
    "text": "Usando um pouco da parte tática, a primeira linha, o jogador que está mais perto"
  },
  {
    "start": 55.82,
    "end": 57.52,
    "text": "do jogador da posse de bola."
  },
  {
    "start": 57.8,
    "end": 61.4,
    "text": "Se adiantou muito e as outras linhas não estavam acompanhando."
  },
  {
    "start": 61.6,
    "end": 64.6,
    "text": "Entrou um jogador no fundo da quadra, livre, e o passe foi feito."
  },
  {
    "start": 65.22,
    "end": 66.94,
    "text": "A capa aqui, o Edmilson, o Tins, vem Schumacher."
  },
  {
    "start": 67.22,
    "end": 68.54,
    "text": "O passe para o Alex de Pico!"
  },
  {
    "start": 69.06,
    "end": 74.64,
    "text": "Gol da Corinthians!"
  },
  {
    "start": 76.42,
    "end": 78.08,
    "text": "Alex empata o jogo!"
  },
  {
    "start": 78.68,
    "end": 81.3,
    "text": "Numa jogada rápida da equipe corintiana!"
  },
  {
    "start": 81.78,
    "end": 86.24,
    "text": "Esta do torcedor da Fiel presente em Florianópolis."
  },
  {
    "start": 86.24,
    "end": 87.24,
    "text": "O Alex foi muito..."
  },
  {
    "start": 87.8,
    "end": 90.2,
    "text": "Muito ágil no que ele recebeu, repare."
  },
  {
    "start": 90.2,
    "end": 92.2,
    "text": "Como o Schumacher faz o passe."
  },
  {
    "start": 92.2,
    "end": 93.4,
    "text": "Olha a rapidez do raciocínio."
  },
  {
    "start": 93.4,
    "end": 98.4,
    "text": "Ele ajeita com o pé esquerdo e já acerta o chute cruzado sem chances para o Carlos,"
  },
  {
    "start": 98.4,
    "end": 100.8,
    "text": "que talvez calculava o passe."
  },
  {
    "start": 104.8,
    "end": 106.8,
    "text": "Agora o Márcio, chute direto."
  },
  {
    "start": 106.8,
    "end": 113.8,
    "text": "Gol de Florianópolis!"
  },
  {
    "start": 114.8,
    "end": 116.8,
    "text": "De novo o passe à frente no placar."
  },
  {
    "start": 116.8,
    "end": 117.6,
    "text": "A equipe catarinense."
  },
  {
    "start": 117.8,
    "end": 119.8,
    "text": "Chute forte do Márcio!"
  },
  {
    "start": 119.8,
    "end": 124.8,
    "text": "E tinha um companheiro dele encostado na trave."
  },
  {
    "start": 124.8,
    "end": 127.8,
    "text": "Gol da equipe de Floripa."
  },
  {
    "start": 127.8,
    "end": 128.8,
    "text": "Mais um minuto."
  },
  {
    "start": 128.8,
    "end": 129.8,
    "text": "Como o chute veio forte."
  },
  {
    "start": 129.8,
    "end": 132.8,
    "text": "A bola bateu no peito do Renatinho e entrou."
  },
  {
    "start": 132.8,
    "end": 134.8,
    "text": "Tem que ter coragem, hein?"
  },
  {
    "start": 134.8,
    "end": 136.8,
    "text": "Para colocar aí..."
  },
  {
    "start": 136.8,
    "end": 138.8,
    "text": "Para colocar o corpo na trajetória da bola."
  },
  {
    "start": 138.8,
    "end": 140.8,
    "text": "Porque veio forte esse chute do Márcio."
  },
  {
    "start": 140.8,
    "end": 141.8,
    "text": "2 a 1 Floripa."
  },
  {
    "start": 141.8,
    "end": 143.8,
    "text": "A gente está vivendo o lance anterior como o Edmilson."
  },
  {
    "start": 143.8,
    "end": 144.8,
    "text": "Acabou esquecendo da bola."
  },
  {
    "start": 144.8,
    "end": 145.8,
    "text": "O chute por cabecura!"
  },
  {
    "start": 145.8,
    "end": 146.8,
    "text": "Boa!"
  },
  {
    "start": 147.8,
    "end": 152.8,
    "text": "Gol de Florianópolis!"
  },
  {
    "start": 152.8,
    "end": 156.8,
    "text": "Guto aumenta a vantagem para a equipe catarinense."
  },
  {
    "start": 156.8,
    "end": 161.8,
    "text": "Aplausos do público do torcedor de Florianópolis."
  },
  {
    "start": 161.8,
    "end": 165.8,
    "text": "Mais uma vez como o Guto do jeito que veio encobriu o goleiro David."
  },
  {
    "start": 165.8,
    "end": 167.8,
    "text": "Que vinha chegando."
  },
  {
    "start": 167.8,
    "end": 169.8,
    "text": "Era mal colocado o goleiro do Corinthians."
  },
  {
    "start": 169.8,
    "end": 171.8,
    "text": "E Florianópolis chega ao terceiro gol."
  },
  {
    "start": 171.8,
    "end": 174.8,
    "text": "Olha como o David saiu para interceptar."
  },
  {
    "start": 174.8,
    "end": 176.8,
    "text": "E aí ficou difícil para tentar evitar."
  },
  {
    "start": 176.8,
    "end": 178.8,
    "text": "3 a 1 Florianópolis."
  },
  {
    "start": 178.8,
    "end": 181.8,
    "text": "Resultado que vai tirando a invencibilidade do Corinthians, Marcelo."
  },
  {
    "start": 181.8,
    "end": 182.8,
    "text": "Um gol espetacular."
  },
  {
    "start": 182.8,
    "end": 183.8,
    "text": "Gol inteligente."
  },
  {
    "start": 183.8,
    "end": 184.8,
    "text": "O jogador estava de frente."
  },
  {
    "start": 184.8,
    "end": 185.8,
    "text": "Botou lá dentro."
  },
  {
    "start": 185.8,
    "end": 186.8,
    "text": "Perfeito."
  },
  {
    "start": 186.8,
    "end": 188.8,
    "text": "Vaias para o Leandro."
  },
  {
    "start": 188.8,
    "end": 189.8,
    "text": "Que arrisca."
  },
  {
    "start": 189.8,
    "end": 190.8,
    "text": "Pegou nas costas do Beto."
  },
  {
    "start": 190.8,
    "end": 192.8,
    "text": "Ficou pelo caminho o Leandro."
  },
  {
    "start": 192.8,
    "end": 193.8,
    "text": "Vem Floripa."
  },
  {
    "start": 193.8,
    "end": 194.8,
    "text": "Renatinho!"
  },
  {
    "start": 194.8,
    "end": 201.8,
    "text": "GOOOOOOOL de Florianópolis!"
  },
  {
    "start": 201.8,
    "end": 204.8,
    "text": "Vira goleada em Santa Catarina."
  },
  {
    "start": 204.8,
    "end": 206.8,
    "text": "Após ter perdido a jogada."
  },
  {
    "start": 206.8,
    "end": 209.8,
    "text": "O Leandro finalizou em cima do Betão."
  },
  {
    "start": 209.8,
    "end": 211.8,
    "text": "O Corinthians ficou desguarnecido."
  },
  {
    "start": 211.8,
    "end": 214.8,
    "text": "E aí o Renatinho só tocou para o gol vazio."
  },
  {
    "start": 214.8,
    "end": 217.8,
    "text": "Marca o gol da equipe de Florianópolis."
  },
  {
    "start": 217.8,
    "end": 220.8,
    "text": "E agora o Renatinho ainda deu uma olhadinha para o lado."
  },
  {
    "start": 220.8,
    "end": 222.8,
    "text": "Teve muita calma Marcelo para aumentar o placar."
  }
]